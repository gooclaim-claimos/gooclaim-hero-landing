# Waitlist form backend
# Copy to .env.local and fill in values. Add the same vars in the Vercel
# dashboard (Project → Settings → Environment Variables) for production.

# Google Apps Script Web App URL for the Waitlist sheet
SHEETS_WEBHOOK_URL=

# Random string that gates writes to the sheet. Must match the value of
# SHARED_SECRET in the Apps Script.
SHEETS_SHARED_SECRET=

# Resend API key with sending access on gooclaim.com
RESEND_API_KEY=

# Internal mailbox that receives "new waitlist signup" notifications
NOTIFY_EMAIL=admin@gooclaim.com

# "From" identity. The domain must be verified in Resend.
FROM_EMAIL=Gooclaim Waitlist <waitlist@gooclaim.com>

# Where replies to the user-facing confirmation email land
REPLY_TO=admin@gooclaim.com
